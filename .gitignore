# ─────────────────────────────────────────────────────────────
# .gitignore — SCT_ML_3 | Task 03: Cat vs Dog SVM
# ─────────────────────────────────────────────────────────────

# ── Python & Jupyter ──────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# ── Virtual Environments ──────────────────────────────────────
.venv/
venv/
env/
ENV/
.env

# ── Dataset (Forces Antigravity to skip raw image folders) ────
cats_set/
dogs_set/
data/
PetImages/
dogs-vs-cats/
*.zip
*.tar.gz
*.rar

# ── Loose Media Extensions (Stops the AI indexing crash) ─────
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.tiff
*.webp

# ── Model Artifacts & Weights ─────────────────────────────────
*.pkl
*.joblib
*.h5
*.model
*.pth
*.onnx

# ── Generated Output Evaluation Files ─────────────────────────
confusion_matrix.png
sample_predictions.png
sample_images.png
pixel_distribution.png
pca_analysis.png
class_distribution.png
metrics_chart.png
confidence_distribution.png
new_image_prediction.png
batch_predictions_*.png
pca_variance.png

# ── Kaggle Credentials ────────────────────────────────────────
kaggle.json

# ── OS / IDE Configs ──────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
.antigravity/
.gemini/

# ── Logs & Temporary Files ────────────────────────────────────
*.log
*.tmp
*.bak